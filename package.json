{
  "name": "chatcat-desktop-pet",
  "version": "1.0.0",
  "description": "ChatCat AI Desktop Pet - Sprite character with keyboard/mouse tracking and AI chat",
  "main": "main.js",
  "scripts": {
    "install:deps": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/install.ps1",
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:all": "electron-builder --win --mac",
    "build:dir": "electron-builder --win --dir",
    "gen-icon": "node scripts/generate-icon.js"
  },
  "author": "",
  "license": "MIT",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "electron-store": "^8.1.0",
    "uiohook-napi": "^1.5.4",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "electron": "^35.7.5",
    "electron-builder": "^26.8.1",
    "sharp": "^0.34.5"
  },
  "build": {
    "appId": "com.chatcat.desktop-pet",
    "productName": "ChatCat",
    "icon": "assets/icon.png",
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.png"
    },
    "mac": {
      "target": [
        {
          "target": "dmg"
        }
      ],
      "icon": "assets/icon.png",
      "category": "public.app-category.entertainment"
    },
    "dmg": {
      "title": "ChatCat",
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "shortcutName": "ChatCat"
    },
    "files": [
      "main.js",
      "preload.js",
      "src/**/*",
      "assets/**/*",
      "node_modules/**/*"
    ],
    "extraResources": [],
    "asar": true
  }
}
