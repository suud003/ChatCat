{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "ChatCat: F5 启动（Dev）",
      "type": "node",
      "request": "launch",
      "preLaunchTask": "deps: ensure installed",
      "postDebugTask": "dev: kill chatcat after debug",
      "cwd": "${workspaceFolder}",
      "runtimeExecutable": "${workspaceFolder}/node_modules/electron/dist/electron.exe",
      "args": [
        "."
      ],
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen",
      "outputCapture": "std",
      "skipFiles": [
        "<node_internals>/**"
      ]
    }
  ]
}
