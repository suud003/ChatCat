{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "ChatCat: F5 启动（Dev）",
      "type": "node",
      "request": "launch",
      "preLaunchTask": "deps: ensure installed",
      "cwd": "${workspaceFolder}",
      "runtimeExecutable": "npm",
      "runtimeArgs": [
        "run",
        "dev"
      ],
      "console": "integratedTerminal",
      "outputCapture": "std",
      "skipFiles": [
        "<node_internals>/**"
      ]
    }
  ]
}
